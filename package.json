{
  "name": "sensebridge-live",
  "version": "1.0.0",
  "private": true,
  "description": "SenseBridge Live — real-time accessibility bridge between deaf/HoH and blind/low-vision users, powered by the Gemini Live API.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"server,web\" -c \"cyan,magenta\" \"npm run dev:server\" \"npm run dev:web\"",
    "dev:web": "vite --host",
    "dev:server": "npm --prefix server run dev",
    "tunnel": "npx --yes cloudflared tunnel --url http://localhost:5173",
    "build": "tsc -b && vite build",
    "build:server": "npm --prefix server run build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && npm --prefix server run typecheck",
    "install:all": "npm install && npm --prefix server install"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^6.5.0",
    "@mui/material": "^6.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
