# ---------------------------------------------------------------------------
# SenseBridge Live — environment configuration
# Copy this file to `server/.env` (backend). A root `.env` is optional.
# ---------------------------------------------------------------------------

# === Backend (server/.env) ===================================================

# TODO: Add your Google Gemini API key here.
# Get one from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Live model for real-time audio -> caption streaming.
# gemini-2.0-flash-live-001 is shut down — use a current Live model.
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# Gemini text model used for /clarify and /summary.
GEMINI_TEXT_MODEL=gemini-3.5-flash

# Model used for Scene Assist vision requests.
# Falls back to GEMINI_TEXT_MODEL if unset.
GEMINI_VISION_MODEL=gemini-3.5-flash

# Port the Express + WebSocket server listens on.
PORT=8080

# Set false to use the real Gemini Live API (requires GEMINI_API_KEY).
# When true (or when no API key is present) captions are simulated.
USE_MOCK_LIVE=false
